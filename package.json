{
  "name": "bitcoinbaby",
  "version": "0.0.1",
  "private": true,
  "pnpm": {
    "overrides": {
      "minimatch": ">=9.0.6",
      "tar": ">=7.5.8"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "signer": "pnpm --filter @bitcoinbaby/signer start",
    "signer:once": "pnpm --filter @bitcoinbaby/signer start:once",
    "signer:test": "pnpm --filter @bitcoinbaby/signer test:e2e",
    "signer:wallet": "pnpm --filter @bitcoinbaby/signer generate-wallet"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.11.0"
}
