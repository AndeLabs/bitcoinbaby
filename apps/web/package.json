{
  "name": "@bitcoinbaby/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next dev",
    "dev:pwa": "SERWIST_SUPPRESS_TURBOPACK_WARNING=1 next dev --webpack",
    "build": "next build --webpack",
    "build:native": "BUILD_TARGET=native next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:build:ios": "pnpm build:native && cap sync ios",
    "cap:build:android": "pnpm build:native && cap sync android",
    "cap:run:ios": "pnpm build:native && cap run ios",
    "cap:run:android": "pnpm build:native && cap run android"
  },
  "dependencies": {
    "@bitcoinbaby/ai": "workspace:*",
    "@bitcoinbaby/bitcoin": "workspace:*",
    "@bitcoinbaby/core": "workspace:*",
    "@bitcoinbaby/ui": "workspace:*",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@serwist/next": "^9.5.6",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.1.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
